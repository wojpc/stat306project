install.packages("car", lib="/usr/local/Cellar/r/4.5.2_1/lib/R/library")
fit1 <- lm(log(size) ~ age_category * log(pgr+1) + nodes + grade, breast_cancer)
summary(fit1)
# QQ plot
plot(fit1, which = 2)
# Cook's distance
plot(fit1, which = 4)
plot(fit1, which = 5)
# Heteroscedasticity check
plot(fit1$fitted.values, fit1$residuals, xlab="Fitted value", ylab="Residual")
confint(fit1)
# Multicollinearity
vif(fit1)
